# ==========================================
# ROS 2 Humble + MoveIt 2 + UR3 / UR driver
# ==========================================

ARG ROS_DISTRO=humble
FROM ros:${ROS_DISTRO}

SHELL ["/bin/bash", "-c"]
ARG DEBIAN_FRONTEND=noninteractive

# Basic tools + ROS build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    curl \
    wget \
    vim \
    nano \
    iputils-ping \
    net-tools \
    python3-pip \
    python3-colcon-common-extensions \
    python3-colcon-mixin \
    python3-rosdep \
    python3-vcstool \
    && rm -rf /var/lib/apt/lists/*

# ROS / MoveIt / UR packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-${ROS_DISTRO}-moveit \
    ros-${ROS_DISTRO}-moveit-common \
    ros-${ROS_DISTRO}-moveit-planners-ompl \
    ros-${ROS_DISTRO}-moveit-ros-planning-interface \
    ros-${ROS_DISTRO}-moveit-servo \
    ros-${ROS_DISTRO}-ur \
    ros-${ROS_DISTRO}-ur-robot-driver \
    ros-${ROS_DISTRO}-ur-description \
    ros-${ROS_DISTRO}-ur-moveit-config \
    ros-${ROS_DISTRO}-ur-msgs \
    ros-${ROS_DISTRO}-controller-manager \
    ros-${ROS_DISTRO}-joint-state-broadcaster \
    ros-${ROS_DISTRO}-joint-trajectory-controller \
    ros-${ROS_DISTRO}-ros2-control \
    ros-${ROS_DISTRO}-ros2-controllers \
    ros-${ROS_DISTRO}-robot-state-publisher \
    ros-${ROS_DISTRO}-joint-state-publisher \
    ros-${ROS_DISTRO}-joint-state-publisher-gui \
    ros-${ROS_DISTRO}-rviz2 \
    ros-${ROS_DISTRO}-tf2-tools \
    ros-${ROS_DISTRO}-xacro \
    ros-${ROS_DISTRO}-angles \
    ros-${ROS_DISTRO}-diagnostic-updater \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-${ROS_DISTRO}-ament-clang-format \
    ros-${ROS_DISTRO}-ament-clang-tidy \
    && rm -rf /var/lib/apt/lists/*

# Initialize rosdep
RUN if [ ! -f /etc/ros/rosdep/sources.list.d/20-default.list ]; then rosdep init; fi && \
    rosdep update

# Colcon mixin
RUN colcon mixin add default https://raw.githubusercontent.com/colcon/colcon-mixin-repository/master/index.yaml || true && \
    colcon mixin update default || true

# Clone dependecies workspace
COPY ./colcon_ws/src /colcon_ws/src

# Solve dependence issues with serial package
WORKDIR /colcon_ws
RUN vcs import src --skip-existing --input src/ros2_robotiq_gripper/ros2_robotiq_gripper-not-released.humble.repos

# Install module dependencies for colcon_ws

RUN . /opt/ros/humble/setup.sh && \
    rosdep install --from-paths src --ignore-src -r -y

# Build the workspace with resource management
RUN source /opt/ros/humble/setup.bash && \
    colcon build --symlink-install

# Copy workspace
COPY ./overlay_ws/src /overlay_ws/src
WORKDIR /overlay_ws

# Optional build step for custom packages
# This only matters if you copied your own packages into /overlay_ws/src
RUN source /opt/ros/${ROS_DISTRO}/setup.bash && \
    source /colcon_ws/install/setup.bash && \
    rosdep install --from-paths /overlay_ws/src --ignore-src --rosdistro ${ROS_DISTRO} -y -r && \
    colcon build --symlink-install

# Source ROS automatically
RUN echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> /root/.bashrc && \
    echo "source /colcon_ws/install/setup.bash" >> /root/.bashrc && \
    echo "source /overlay_ws/install/setup.bash" >> /root/.bashrc

WORKDIR /overlay_ws
CMD ["bash"]